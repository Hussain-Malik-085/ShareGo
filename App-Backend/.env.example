# Copy to .env and edit
PORT=4000
#
# MONGODB_URI (pick ONE):
# 1) Local: only works if "mongod" is running; default port 27017
#    MONGODB_URI=mongodb://127.0.0.1:27017/sharego
# 2) Cloud (no local install): free tier — https://www.mongodb.com/cloud/atlas
#    Create cluster → Database Access: user+password
#    Network Access: Add IP 0.0.0.0/0 (dev) or your IP
#    Connect → Drivers → copy URI, replace <password>
#    MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/sharego?retryWrites=true&w=majority
#
# If you see ECONNREFUSED 127.0.0.1:27017, local Mongo is not running — use Atlas (2) or: brew services start mongodb-community (Mac)
MONGODB_URI=mongodb://127.0.0.1:27017/sharego

# Shown in app fuel screens (any string your UI can parse)
PETROL_PRICE_DISPLAY=Rs. 280/Ltr
