# Copy to .env in this folder, then set real values.
# Android emulator: use 10.0.2.2 to reach your PC's localhost
# iOS simulator:   use localhost
# Physical phone:    use your computer's LAN IP, e.g. 192.168.1.10

API_BASE_URL=http://10.0.2.2:4000/api

# Supabase (Authentication > Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Cloudinary (unsigned upload: Settings > Upload > Upload presets)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
