# REQUIRED: copy this file to `.env` in this folder (same directory as package.json).
# Metro only loads `.env` — editing `.env.example` alone will NOT change the running app.
# Android emulator: use 10.0.2.2 to reach your PC's localhost
# iOS simulator:   use localhost
# Physical phone:    use your computer's LAN IP, e.g. 192.168.1.10

API_BASE_URL=http://10.0.2.2:4000/api

# Supabase (required for login/signup) — create a project at https://supabase.com
# Project Settings → API → Project URL + anon public (or publishable) key
SUPABASE_URL=https://kdfjbwqmqmrkzczjfjpc.supabase.co
# Client-safe key only. NEVER put sb_secret_* or service_role here.
SUPABASE_ANON_KEY=sb_publishable_2FcdCvd6LLJYhLFlQRS9Iw_8I7Qrqrw

# Cloudinary — REQUIRED for profile / CNIC / license / vehicle photos
# 1) https://cloudinary.com → free account
# 2) Dashboard → copy "Cloud name" below
# 3) Settings → Upload → Upload presets → Add → Signing mode: Unsigned → save → copy preset name
# 4) Restart Metro after editing: npm start -- --reset-cache
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
# Optional for unsigned presets (leave empty if preset is Unsigned)
CLOUDINARY_API_KEY=
