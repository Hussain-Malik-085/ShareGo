def node_require(script)
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, min_ios_version_supported
prepare_react_native_project!

setup_permissions([
  'Camera',
  'PhotoLibrary',
])

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Share_Go' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    # react-native-maps needs RNMapsAirModule in the native binary; Fabric/Bridgeless builds often hit a TurboModule registration mismatch until pods + Xcode rebuild cleanly.
    # Old Architecture avoids RNMapsAirModule / Fabric Map path issues during development.
    :fabric_enabled => false,
    :new_arch_enabled => false,
  )

  target 'Share_GoTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # react-native-maps ships Fabric-only sources that fail when New Architecture is off.
    fabric_maps_patterns = [
      'RNMapsMapView',
      'RNMapsMarkerView',
      'RNMapsGoogleMapView',
      'RNMapsGooglePolygonView',
      'PlaceHolderPolygonView',
      'PlaceHolderGoogleMapView',
    ]
    installer.pods_project.targets.each do |target|
      next unless target.name == 'react-native-maps'

      target.source_build_phase.files.to_a.each do |build_file|
        path = build_file.file_ref&.path.to_s
        next if path.empty?

        if fabric_maps_patterns.any? { |name| path.include?(name) }
          target.source_build_phase.files.delete(build_file)
        end
      end
    end
  end
end
